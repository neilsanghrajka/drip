# Copy this file to `.env` or `.env.local` and fill values privately.
# Do not commit real Convex/Vercel deployment values or deploy keys.

# Convex deployment selected by `pnpm exec convex dev` for local development.
CONVEX_DEPLOYMENT=

# Public Convex client URL used by Next.js. Local development reads this from
# `.env.local`; production is injected during Vercel builds by `convex deploy`.
NEXT_PUBLIC_CONVEX_URL=

# Optional public Convex HTTP actions URL generated by `pnpm exec convex dev`.
NEXT_PUBLIC_CONVEX_SITE_URL=

# Optional Convex URL override passed from Convex actions to sandbox runners.
# Product actions fall back to Convex's built-in CONVEX_CLOUD_URL when available.
DRIP_RUNNER_CONVEX_URL=

# Production-only Convex deploy key for Vercel. Never commit a real value.
CONVEX_DEPLOY_KEY=

# Public app URL for deployment smoke checks and self-host documentation.
NEXT_PUBLIC_APP_URL=

# Active Vercel Sandbox base snapshot ID. Updated privately by
# `pnpm run setup:base-snapshot`; never commit a real value.
BASE_SANDBOX_IMAGE=

# Phase A sandbox/Codex SDK prototype. Keep values private.
# The same ingest token must be configured in Convex env.
SANDBOX_PROTOTYPE_INGEST_TOKEN=

# Codex SDK auth for sandbox runner commands.
# Use an OpenAI Platform API key (`sk-...`), preferably disposable for Phase A.
OPENAI_API_KEY=
CODEX_API_KEY=
CODEX_MODEL=
CODEX_REASONING_EFFORT=

# Vercel Sandbox auth. The local setup command can use VERCEL_TOKEN or
# VERCEL_OIDC_TOKEN. Convex product runs require VERCEL_TOKEN because actions run
# outside Vercel's OIDC context. Drip requires team/project IDs with sandbox auth.
VERCEL_OIDC_TOKEN=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Active sandbox setup/runtime overrides.
DRIP_HEARTBEAT_MS=
DRIP_SANDBOX_RUNNER_TIMEOUT_MS=
DRIP_SANDBOX_RUNNER_CWD=
DRIP_SANDBOX_RUNNER_ENTRYPOINT=
DRIP_SANDBOX_AGENT_WORKDIR=
DRIP_SANDBOX_TIMEOUT_MS=
DRIP_SANDBOX_RUNTIME=
DRIP_SANDBOX_VCPUS=

# Base snapshot setup command dependency install timeout.
DRIP_SANDBOX_INSTALL_TIMEOUT_MS=

# Phase A sandbox/Codex SDK prototype-only overrides.
# These are not part of the product sandbox run contract.
DRIP_CONVEX_INGEST_URL=
DRIP_SANDBOX_NAME=
