# Copy this file to `.env` and fill values privately.
# Do not commit real Convex/Vercel deployment values or deploy keys.

# Convex deployment selected by `pnpm exec convex dev` for local development.
CONVEX_DEPLOYMENT=

# Public Convex client URL used by Next.js. Local development reads this from
# `.env`; production is injected during Vercel builds by `convex deploy`.
NEXT_PUBLIC_CONVEX_URL=

# Optional public Convex URL passed to external sandbox runners for callbacks.
# Set this in Convex env when `CONVEX_CLOUD_URL` is not externally reachable.
DRIP_RUNNER_CONVEX_URL=
DRIP_RUNNER_CALLBACK_PREFLIGHT_TIMEOUT_MS=

# Optional public Convex HTTP actions URL generated by `pnpm exec convex dev`.
NEXT_PUBLIC_CONVEX_SITE_URL=

# Convex Auth JWT signing config. Generate privately and set these on the
# selected Convex deployments; never commit real key material.
JWT_PRIVATE_KEY=
JWKS=

# Production-only Convex deploy key for Vercel. Never commit a real value.
CONVEX_DEPLOY_KEY=

# Public app URL for deployment smoke checks and self-host documentation.
NEXT_PUBLIC_APP_URL=

# Active Vercel Sandbox base snapshot ID. Updated privately in `.env`, selected
# Convex, and prod Convex by `pnpm run setup:base-snapshot`; never commit a real
# value.
BASE_SANDBOX_IMAGE=

# Phase A sandbox/Codex SDK prototype. Keep values private.
# The same ingest token must be configured in Convex env.
SANDBOX_PROTOTYPE_INGEST_TOKEN=

# Codex SDK auth for sandbox runner commands.
# Use an OpenAI Platform API key (`sk-...`), preferably disposable for Phase A.
OPENAI_API_KEY=
CODEX_API_KEY=
CODEX_MODEL=
CODEX_REASONING_EFFORT=
CODEX_WEB_SEARCH_MODE=
DRIP_CODEX_NETWORK_ACCESS_ENABLED=

# Scout research credentials. Keep real values private.
EXA_API_KEY=
X_BEARER_TOKEN=
TWITTER_BEARER_TOKEN=

# Meta Ads CLI credentials for sandbox agents. The runner maps these to the
# official CLI names (`ACCESS_TOKEN`, `AD_ACCOUNT_ID`, `BUSINESS_ID`) inside the
# sandbox Codex process. Keep real values private.
META_ADS_ACCESS_TOKEN=
META_ADS_AD_ACCOUNT_ID=
META_ADS_BUSINESS_ID=
META_ADS_PAGE_ID=

# Vercel Sandbox auth. The local setup command can use VERCEL_TOKEN or
# VERCEL_OIDC_TOKEN. Convex product runs require VERCEL_TOKEN because actions run
# outside Vercel's OIDC context. Drip requires team/project IDs with sandbox auth.
VERCEL_OIDC_TOKEN=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Builder drop-site deployment. Builder deploys immutable preview deployments to
# the dedicated Vercel project and returns the deployment URL as the historical
# live link. Use a dedicated token when possible; for hackathon runs it may be
# populated from the same private Vercel token used for sandbox auth.
VERCEL_DEPLOY_TOKEN=
DRIP_DROP_SITES_VERCEL_PROJECT=drip-websites
DRIP_DROP_SITES_VERCEL_SCOPE=

# Active sandbox setup/runtime overrides.
DRIP_HEARTBEAT_MS=
DRIP_SANDBOX_RUNNER_TIMEOUT_MS=
DRIP_RUNNER_CONVEX_REQUEST_TIMEOUT_MS=
DRIP_SANDBOX_RUNNER_CWD=
DRIP_SANDBOX_RUNNER_ENTRYPOINT=
DRIP_SANDBOX_AGENT_WORKDIR=
DRIP_SANDBOX_TIMEOUT_MS=
DRIP_SANDBOX_RUNTIME=
DRIP_SANDBOX_VCPUS=
DRIP_DROP_SANDBOX_SNAPSHOT_TTL_MS=
DRIP_DROP_SANDBOX_KEEP_SNAPSHOTS=

# E2E smoke harness debugging. Set to 1 to keep failing sandboxes for inspection.
DRIP_E2E_KEEP_SANDBOX_ON_FAILURE=

# Base snapshot setup command dependency install timeout.
DRIP_SANDBOX_INSTALL_TIMEOUT_MS=

# Phase A sandbox/Codex SDK prototype-only overrides.
# These are not part of the product sandbox run contract.
DRIP_CONVEX_INGEST_URL=
DRIP_SANDBOX_NAME=
